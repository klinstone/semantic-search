# PostgreSQL configuration
POSTGRES_USER=semsearch
POSTGRES_PASSWORD=local_dev_password
POSTGRES_DB=semantic_search
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Qdrant configuration
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=document_multilingual-e5-base

# Embedding model
# При смене модели также поменять EMBEDDING_DIM и переиндексировать
# (см. план: dim зашит в коллекцию Qdrant при создании).
#   intfloat/multilingual-e5-base   -> 768
#   intfloat/multilingual-e5-large  -> 1024
#   sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2 -> 384
# VARIANTS:
#   intfloat/multilingual-e5-base   768     "query: "   "passage: "
#   sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2     384     ""      ""
#   BAAI/bge-m3     1024    "Represent this sentence for searching relevant passages: "     ""
EMBEDDING_MODEL=intfloat/multilingual-e5-base
EMBEDDING_DIM=768
EMBEDDING_QUERY_PREFIX="query: "
EMBEDDING_PASSAGE_PREFIX="passage: "

# Application configuration
APP_ENV=development
APP_LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=10

# CORS — JSON-список origin'ов фронтенда
CORS_ORIGINS=["http://localhost:5173"]

# Port exposed on host machine
BACKEND_PORT=8000

RERANKING_ENABLED=true
RERANKING_MODEL=BAAI/bge-reranker-v2-m3
RERANKING_POOL_FACTOR=5