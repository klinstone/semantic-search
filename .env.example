# PostgreSQL configuration
POSTGRES_USER=semsearch
POSTGRES_PASSWORD=change_me_in_env
POSTGRES_DB=semantic_search
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Qdrant configuration
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Application configuration
APP_ENV=development
APP_LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=10

# Port exposed on host machine
BACKEND_PORT=8000