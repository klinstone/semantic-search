# URL бэкенда для dev-прокси Vite. Используется только в `npm run dev`.
# В docker-compose и production проксирование делает nginx, эта переменная не нужна.
VITE_BACKEND_URL=http://localhost:8000

# Базовый URL API клиента. По умолчанию /api/v1 — относительный путь,
# который автоматически уходит через прокси (Vite в dev, nginx в prod).
# VITE_API_BASE_URL=/api/v1
